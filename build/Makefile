.PHONY : src/service/server.s

# target to generate assembly for a file
src/service/server.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/server.dir/build.make CMakeFiles/server.dir/src/service/server.cpp.s
.PHONY : src/service/server.cpp.s

